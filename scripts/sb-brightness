#!/bin/sh

bri=$(xbacklight -get)

if [[ $bri -lt 15 ]]; then
    icon="ď—™"
elif [[ $bri -lt 30 ]]; then
    icon="ď—š"
elif [[ $bri -lt 45 ]]; then
    icon="ď—›"
elif [[ $bri -lt 60 ]]; then
    icon="ď—ś"
elif [[ $bri -lt 75 ]]; then
    icon="ď—ť"
elif [[ $bri -lt 90 ]]; then
    icon="ď—ž"
else
    icon="ď—ź"
fi

echo "$icon $bri%"
